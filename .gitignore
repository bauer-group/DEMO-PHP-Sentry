# =============================================================================
# Git Ignore - Sentry Mini Project
# =============================================================================

# Dependency & Build
# Composer dependencies and lock files
# ─────────────────────────────────────────────────────────────────────────────
vendor/
composer.lock

# Environment & Configuration
# Local environment variables and overrides (NEVER commit!)
# ─────────────────────────────────────────────────────────────────────────────
.env
.env.local
.env.*.local

# IDE & OS Files
# macOS, PHPStorm/IntelliJ, VS Code, Vim, and Eclipse project files
# ─────────────────────────────────────────────────────────────────────────────
.DS_Store
.idea/
.vscode/
*.swp
*.swo
*~
.project

# Logs & Temporary
# Log files, temporary files, and cache directories
# ─────────────────────────────────────────────────────────────────────────────
*.log
*.tmp
.cache/

# Testing
# PHPUnit cache
# ─────────────────────────────────────────────────────────────────────────────
.phpunit.result.cache
