{
    "name": "demo/sentry-mini",
    "version": "0.1.0",
    "description": "Mini Sentry Integration Project",
    "require": {
        "php": ">=8.0",
        "sentry/sentry": "^4.0",
        "vlucas/phpdotenv": "^5.6"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    }
}
